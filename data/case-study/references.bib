@inproceedings{brumitt2000easyliving,
	title        = {EasyLiving: Technologies for Intelligent Environments},
	author       = {Brumitt, Barry and Meyers, Brian and Krumm, John and Kern, Amanda and Shafer, Steven},
	year         = {2000},
	month        = {09},
	booktitle    = {Second International Symposium on Handheld and Ubiqitous Computing (HUC 2000), Bristol, UK},
